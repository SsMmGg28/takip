# Supabase proje ayarları (Supabase Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SADECE sunucu tarafında kullanılır, asla tarayıcıya / git'e gönderilmez
SUPABASE_SERVICE_ROLE_KEY=

# Kullanıcı adlarını teknik e-postaya çevirmek için kullanılan sabit alan adı (örn. "ahmet.yilmaz@takip.internal")
NEXT_PUBLIC_AUTH_EMAIL_DOMAIN=takip.internal

# Web Push (kilit ekranı bildirimleri) için VAPID anahtarları.
# Üretmek için: npx web-push generate-vapid-keys
# Public key tarayıcıya gider; private key SADECE sunucuda kalır.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Push servislerine iletilen iletişim adresi (mailto:... biçiminde)
VAPID_SUBJECT=mailto:admin@example.com
