# Supabase proje ayarları (Supabase Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SADECE sunucu tarafında kullanılır, asla tarayıcıya / git'e gönderilmez
SUPABASE_SERVICE_ROLE_KEY=

# Kullanıcı adlarını teknik e-postaya çevirmek için kullanılan sabit alan adı (örn. "ahmet.yilmaz@takip.internal")
NEXT_PUBLIC_AUTH_EMAIL_DOMAIN=takip.internal

# Web Push (kilit ekranı bildirimleri) için VAPID anahtarları.
# Üretmek için: npx web-push generate-vapid-keys
# Public key tarayıcıya gider; private key SADECE sunucuda kalır.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Push servislerine iletilen iletişim adresi (mailto:... biçiminde)
VAPID_SUBJECT=mailto:admin@example.com

# Vercel cron isteklerini doğrulayan gizli anahtar (Vercel otomatik gönderir;
# projede Environment Variables > CRON_SECRET olarak da tanımlanmalı).
# Üretmek için: openssl rand -hex 32
CRON_SECRET=

# Deneme sonuç belgesini (PDF/foto) okuyup formu otomatik dolduran yapay zeka.
# SADECE sunucu tarafında kullanılır; anahtar tanımlı değilse özellik kapanır,
# kullanıcı sonuçları elle girer. Anahtar: https://aistudio.google.com/apikey
# Gizlilik notu: yüklenen belge saklanmaz; yalnızca istek süresince Gemini'ye
# gönderilir. Öğrenci verisi işlendiği için üretimde ücretsiz katman yerine
# veriyi eğitimde kullanmayan ücretli/kurumsal katman tercih edilmelidir.
GEMINI_API_KEY=
# Kullanılacak model (opsiyonel; varsayılan: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# ============================================================================
# SADECE GELİŞTİRME / ÖN İZLEME — PROD'DA ASLA TANIMLAMA
# ----------------------------------------------------------------------------
# Bir yapay zeka ajanının (veya geliştiricinin) rolleri oturum açma zahmeti
# olmadan gezebilmesi için dev-only otomatik giriş rotası (/api/dev/preview-login).
# Bu değişkenler tanımlıysa bile NODE_ENV=production iken rota 404 döner.
# Prod build'de bu iki değeri TANIMLAMA; seed hesaplarını prod DB'ye AÇMA.
# Üretmek için: openssl rand -hex 32
DEV_PREVIEW_SECRET=
# preview.teacher / preview.student / preview.parent hesaplarının şifresi.
# scripts/seed-preview.mjs bu şifreyle hesapları oluşturur.
DEV_PREVIEW_PASSWORD=
